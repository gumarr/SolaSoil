// Prisma schema - khớp hoàn toàn với Supabase SQL schema
// Chạy: npx prisma db push && npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ── Bảng categories ──────────────────────────────────────
model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  icon        String?
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz

  // Relations
  products Product[]

  @@map("categories")
}

// ── Bảng products ────────────────────────────────────────
model Product {
  id             String    @id @default(uuid()) @db.Uuid
  category_id    String?   @db.Uuid
  name           String
  description    String?
  price          Decimal   @db.Decimal
  weight         String?
  stock_quantity Int?      @default(0)
  images         String[]
  ocop_stars     Int?
  origin         String?   @default("Sơn La")
  is_active      Boolean?  @default(true)
  created_at     DateTime? @default(now()) @db.Timestamptz

  // Relations
  category   Category?   @relation(fields: [category_id], references: [id])
  order_items OrderItem[]
  combo_items ComboItem[]

  @@map("products")
}

// ── Bảng users ───────────────────────────────────────────
model User {
  id         String    @id @default(uuid()) @db.Uuid
  full_name  String?
  email      String?   @unique
  phone      String?
  address    String?
  role       String?   @default("customer")
  created_at DateTime? @default(now()) @db.Timestamptz

  // Relations
  orders Order[]

  @@map("users")
}

// ── Bảng combos ──────────────────────────────────────────
model Combo {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  base_price     Decimal?  @default(0) @db.Decimal
  total_price    Decimal   @db.Decimal
  is_customizable Boolean? @default(false)
  created_at     DateTime? @default(now()) @db.Timestamptz

  // Relations
  combo_items ComboItem[]
  order_items OrderItem[]

  @@map("combos")
}

// ── Bảng combo_items ─────────────────────────────────────
model ComboItem {
  combo_id   String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Int?    @default(1)

  // Relations
  combo   Combo   @relation(fields: [combo_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@id([combo_id, product_id])
  @@map("combo_items")
}

// ── Bảng orders ──────────────────────────────────────────
model Order {
  id               String    @id @default(uuid()) @db.Uuid
  user_id          String?   @db.Uuid
  total_amount     Decimal   @db.Decimal
  status           String?   @default("pending")
  shipping_address String
  payment_method   String?
  full_name        String?
  phone            String?
  created_at       DateTime? @default(now()) @db.Timestamptz

  // Relations
  user        User?       @relation(fields: [user_id], references: [id])
  order_items OrderItem[]

  @@map("orders")
}

// ── Bảng order_items ─────────────────────────────────────
model OrderItem {
  id                String   @id @default(uuid()) @db.Uuid
  order_id          String?  @db.Uuid
  product_id        String?  @db.Uuid
  combo_id          String?  @db.Uuid
  quantity          Int
  price_at_purchase Decimal  @db.Decimal

  // Relations
  order   Order?   @relation(fields: [order_id], references: [id])
  product Product? @relation(fields: [product_id], references: [id])
  combo   Combo?   @relation(fields: [combo_id], references: [id])

  @@map("order_items")
}
