// Prisma schema - khớp hoàn toàn với Supabase SQL schema
// Chạy: npx prisma db push && npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ── Bảng categories ──────────────────────────────────────
model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  icon        String?
  description String?
  subtitle    String?
  grad        String?   @default("from-stone-900 to-amber-900")
  image_url   String?
  created_at  DateTime? @default(now()) @db.Timestamptz

  // Relations
  products Product[]

  @@map("categories")
}

// ── Bảng products ────────────────────────────────────────
model Product {
  id                 String    @id @default(uuid()) @db.Uuid
  category_id        String?   @db.Uuid
  name               String
  description        String?
  price              Decimal   @db.Decimal
  weight             String?
  stock_quantity     Int?      @default(0)
  images             String[]
  ocop_stars         Int?
  origin             String?   @default("Sơn La")
  is_active          Boolean?  @default(true)
  image_main         String?
  image_reveal       String?
  image_thumb        String?
  emoji              String?   @default("📦")
  reveal_emoji       String?   @default("✨")
  grad               String?   @default("from-stone-800 via-stone-700 to-amber-900")
  reveal_grad        String?   @default("from-orange-700 via-red-700 to-rose-800")
  badge              String?
  detail_story       String?
  ingredients        String?
  usage_instructions String?
  benefits           String?
  created_at         DateTime? @default(now()) @db.Timestamptz

  // Relations
  category   Category?   @relation(fields: [category_id], references: [id])
  order_items OrderItem[]
  combo_items ComboItem[]

  @@map("products")
}

// ── Bảng users ───────────────────────────────────────────
model User {
  id         String    @id @default(uuid()) @db.Uuid
  full_name  String?
  email      String?   @unique
  phone      String?
  address    String?
  role       String?   @default("customer")
  created_at DateTime? @default(now()) @db.Timestamptz

  // Relations
  orders        Order[]
  chat_sessions ChatSession[]

  @@map("users")
}

// ── Bảng combos ──────────────────────────────────────────
model Combo {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  base_price     Decimal?  @default(0) @db.Decimal
  total_price    Decimal   @db.Decimal
  is_customizable Boolean? @default(false)
  created_at     DateTime? @default(now()) @db.Timestamptz

  // Relations
  combo_items ComboItem[]
  order_items OrderItem[]

  @@map("combos")
}

// ── Bảng combo_items ─────────────────────────────────────
model ComboItem {
  combo_id   String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Int?    @default(1)

  // Relations
  combo   Combo   @relation(fields: [combo_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@id([combo_id, product_id])
  @@map("combo_items")
}

// ── Bảng orders ──────────────────────────────────────────
model Order {
  id               String    @id @default(uuid()) @db.Uuid
  user_id          String?   @db.Uuid
  total_amount     Decimal   @db.Decimal
  status           String?   @default("pending")
  shipping_address String
  payment_method   String?
  full_name        String?
  phone            String?
  created_at       DateTime? @default(now()) @db.Timestamptz

  // Relations
  user        User?       @relation(fields: [user_id], references: [id])
  order_items OrderItem[]

  @@map("orders")
}

// ── Bảng order_items ─────────────────────────────────────
model OrderItem {
  id                String   @id @default(uuid()) @db.Uuid
  order_id          String?  @db.Uuid
  product_id        String?  @db.Uuid
  combo_id          String?  @db.Uuid
  quantity          Int
  price_at_purchase Decimal  @db.Decimal

  // Relations
  order   Order?   @relation(fields: [order_id], references: [id])
  product Product? @relation(fields: [product_id], references: [id])
  combo   Combo?   @relation(fields: [combo_id], references: [id])

  @@map("order_items")
}

// ── Bảng chat_sessions ───────────────────────────────────
model ChatSession {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String?   @db.Uuid
  session_key   String    @unique
  customer_name String    @default("Khách hàng")
  created_at    DateTime? @default(now()) @db.Timestamptz
  updated_at    DateTime? @default(now()) @db.Timestamptz

  // Relations
  messages      ChatMessage[]
  user          User?     @relation(fields: [user_id], references: [id])

  @@map("chat_sessions")
}

// ── Bảng chat_messages ───────────────────────────────────
model ChatMessage {
  id          String    @id @default(uuid()) @db.Uuid
  session_id  String    @db.Uuid
  sender_id   String?   @db.Uuid
  sender_role String    @default("customer") // "customer" or "admin"
  content     String
  is_read     Boolean   @default(false)
  created_at  DateTime? @default(now()) @db.Timestamptz

  // Relations
  session     ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ── Bảng gift_combos ──────────────────────────────────────
model GiftCombo {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Decimal   @db.Decimal
  image_url   String?
  emoji       String?   @default("🎁")
  grad        String?   @default("from-stone-800 to-green-900")
  tag         String?
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz

  @@map("gift_combos")
}

// ── Bảng testimonials ─────────────────────────────────────
model Testimonial {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  role       String?
  text       String
  location   String?
  rating     Int?      @default(5)
  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamptz

  @@map("testimonials")
}

// ── Bảng site_config ──────────────────────────────────────
model SiteConfig {
  key        String    @id
  value      Json
  updated_at DateTime? @default(now()) @db.Timestamptz

  @@map("site_config")
}
